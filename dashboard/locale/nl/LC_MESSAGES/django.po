#: templates/dashboard/user_areas.html:21
msgid "Upload a new area"
msgstr "Upload een nieuw gebied"

#: templates/dashboard/user_areas.html:25
msgid ""
"\n"
"                    <p><i class=\"bi bi-info-square\"></i> The following "
"contraints apply to the uploaded file:</p>\n"
"                    <ul>\n"
"                        <li>it must be a <b><a href=\"https://"
"en.wikipedia.org/wiki/GeoPackage\">GeoPackage</a></b> (many external tools "
"exist to convert other file formats to GeoPackages)</li>\n"
"                        <li>it must contain a <b>single layer</b></li>\n"
"                        <li>the layer must contain a <b>single feature</b> "
"of type <b>polygon</b> or <b>multipolygon</b></li>\n"
"                        <li>the GeoPackage must have a valid coordinate "
"reference system</li>\n"
"                    </ul>\n"
"                    "
msgstr ""
"\n"
"                    <p><i class=\"bi bi-info-square\"></i> De volgende "
"beoerkingen gelden voor het bestand:</p>\n"
"                    <ul>\n"
"                        <li>het moet een <b><a href=\"https://"
"en.wikipedia.org/wiki/GeoPackage\">GeoPackage</a></b> (er bestaan veel "
"externe tools om andere bestandsformaten om te zetten naar GeoPackages)</"
"li>\n"
"                        <li>het moet een <b>single layer</b> bevatten </li>\n"
"                        <li>het moet een <b>single feature</b> bevattenvan "
"het type <b>polygon</b> of <b>multipolygon</b></li>\n"
"                        <li>het GeoPackage moet een geldig "
"coördinatenreferentiesysteem bevatten</li>\n"
"                    </ul>\n"
"                    "

